<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="ac.csg.pu.gui.dashboard.commercial.OrdersController"
            stylesheets="@../dashboard.css, @../components.css"
            styleClass="page-background">

    <VBox spacing="16"
          AnchorPane.topAnchor="40"
          AnchorPane.bottomAnchor="40"
          AnchorPane.leftAnchor="180"
          AnchorPane.rightAnchor="180"
          styleClass="panel">

        <HBox alignment="CENTER_LEFT" spacing="12">
            <Button text="Back" onAction="#goBack" styleClass="back-button"/>
            <Label text="Your Orders" styleClass="heading"/>
        </HBox>

        <Separator/>

        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="scroll-pane">
            <VBox fx:id="ordersContainer" spacing="12">
                <padding>
                    <Insets top="4" right="4" bottom="4" left="4"/>
                </padding>
            </VBox>
        </ScrollPane>

    </VBox>

</AnchorPane>
