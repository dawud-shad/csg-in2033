<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="ac.csg.pu.gui.dashboard.commercial.CartCardController"
      spacing="5" styleClass="cart-card" style="-fx-padding: 10; -fx-border-color: #dcdfe3; -fx-border-radius: 5; -fx-background-color: white; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 5,0,0,2);">

    <HBox spacing="5">
        <Label fx:id="nameLabel" styleClass="heading"/>
        <Label fx:id="promotionLabel" styleClass="promo"/>
    </HBox>

    <HBox spacing="5" alignment="CENTER_LEFT">
        <Button fx:id="minusButton" text="–"/>
        <Label fx:id="quantityLabel"/>
        <Button fx:id="plusButton" text="+"/>
        <Label fx:id="totalPriceLabel" styleClass="new-price"/>
    </HBox>
</VBox>